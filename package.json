		"@fastify/sensible": "^6.0.4",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.5",
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@react-email/components": "^1.0.8",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.3.1",
		"fastify": "^5.7.4",
